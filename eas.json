{
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "distribution": "internal",
      "env": {
        "EXPO_PUBLIC_API_URL": "https://api.a1carehospital.in/api"
      }
    },
    "production": {
      "ios": {
        "image": "latest",
        "credentialsSource": "remote"
      },
      "android": {
        "credentialsSource": "local"
      },
      "autoIncrement": true,
      "env": {
        "NPM_CONFIG_LEGACY_PEER_DEPS": "true",
        "EXPO_PUBLIC_API_URL": "https://api.a1carehospital.in/api"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "goexpertsapps@gmail.com",
        "ascAppId": "6765998915",
        "appleTeamId": "Z8UNCTCRRH"
      },
      "android": {
        "serviceAccountKeyPath": "./google-play-service-account.json",
        "track": "production"
      }
    }
  }
}
